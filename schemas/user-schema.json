{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "uid": {
            "type": "string"
        },
        "nickname": {
            "type": "string"
        },
        "email": {
            "type": "string"
        },
        "photoUrl": {
            "type": "string"
        },
        "role": {
            "enum": [
                "user",
                "moderator",
                "admin"
            ]
        },
        "gender": {
            "enum": [
                "male",
                "female",
                "non-binary",
                ""
            ]
        },
        "interestedIn": {
            "type": "string"
        },
        "banned": {
            "type": "boolean"
        },
        "birthDate": {
            "type": "string"
        },
        "createdAt": {
            "type": "string"
        }
    },
    "required": [
        "uid",
        "nickname"
    ]
}