rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isModerator() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "moderator"];
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read and write their own document
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Admins and moderators can read and write ANY user document
      allow read, write: if isModerator();

      // Other signed-in users can read basic profile info
      // (needed for chat list, feed nicknames, etc.)
      allow read: if isSignedIn();
    }

    // ── Posts ─────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      // Moderators and admins can delete any post
      allow delete: if isModerator();
    }

    // ── Connections ──────────────────────────────────────────────────
    match /connections/{connectionId} {
      allow read: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/connections/$(connectionId)).data.fromUserId == request.auth.uid ||
          get(/databases/$(database)/documents/connections/$(connectionId)).data.toUserId == request.auth.uid
        );
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ── Moderation Logs ──────────────────────────────────────────────
    match /moderation_logs/{logId} {
      allow read: if isModerator();
      allow create: if isModerator();
    }
  }
}
